					},
					"name": "Show Sale",
					"ownedElements": [
						{
							"_type": "UMLExtend",
							"_id": "AAAAAAGbEou3DZKKcZA=",
							"_parent": {
								"$ref": "AAAAAAGbEot1N5DcFPY="
